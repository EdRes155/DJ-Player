# ============ SPOTIFY ============
# Crea tu app en https://developer.spotify.com/dashboard
# Redirect URI: http://127.0.0.1:5173/callback (dev) y https://TU-APP.vercel.app/callback (prod)
VITE_SPOTIFY_CLIENT_ID=tu_client_id_aqui
VITE_SPOTIFY_REDIRECT_URI=http://127.0.0.1:5173/callback

# ============ ELEVENLABS (voz del DJ) ============
# API key en https://elevenlabs.io -> Profile -> API Keys
VITE_ELEVENLABS_API_KEY=tu_api_key_aqui
# Voz recomendada en español: busca una voz "conversational" en la librería y pega su ID
VITE_ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL

# ============ OPCIONAL: LLM para guiones del DJ ============
# Si lo dejas vacío, el DJ usa el generador de guiones local (djScript.js)
VITE_LLM_API_URL=

# ============ VOZ DEL DJ ============
# auto = ElevenLabs si hay key válida, si no la voz del navegador (gratis)
# local = siempre navegador (gratis, sin key, español nativo). RECOMENDADO en free tier.
# elevenlabs = solo ElevenLabs
VITE_TTS_PROVIDER=local
